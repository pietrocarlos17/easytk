        "5174",
        "-c-1",
        "--silent"
      ],
      "port": 5174
    },
    {
      "name": "dyson-eua-sirius",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "-y",
        "http-server",
        "dyson-eua-sirius",
        "-p",
        "5175",
        "-c-1",
        "--silent"
