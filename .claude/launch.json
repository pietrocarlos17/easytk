{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "start"
      ],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "server/server.js"
      ],
      "port": 4000
    },
    {
